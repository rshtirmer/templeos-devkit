{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HolyC",
  "scopeName": "source.holyc",
  "fileTypes": ["ZC", "HC", "HH"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#preprocessor" },
    { "include": "#strings" },
    { "include": "#chars" },
    { "include": "#numbers" },
    { "include": "#constants" },
    { "include": "#storage-modifiers" },
    { "include": "#types" },
    { "include": "#control-keywords" },
    { "include": "#other-keywords" },
    { "include": "#asm-block" },
    { "include": "#function-definition" },
    { "include": "#builtin-functions" },
    { "include": "#function-call" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.holyc",
          "begin": "//",
          "end": "$",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.holyc" }
          }
        },
        {
          "name": "comment.block.holyc",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.begin.holyc" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.comment.end.holyc" }
          }
        }
      ]
    },
    "preprocessor": {
      "patterns": [
        {
          "name": "meta.preprocessor.include.holyc",
          "begin": "^\\s*(#\\s*include)\\b",
          "end": "$",
          "beginCaptures": {
            "1": { "name": "keyword.control.directive.include.holyc" }
          },
          "patterns": [
            { "include": "#strings" },
            { "include": "#comments" }
          ]
        },
        {
          "name": "meta.preprocessor.holyc",
          "match": "^\\s*(#\\s*(?:define|undef|if|ifdef|ifndef|else|elif|endif|exe|help_index|help_file|help_link|asm|pragma|line|error|warning))\\b",
          "captures": {
            "1": { "name": "keyword.control.directive.holyc" }
          }
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.holyc",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.holyc" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.holyc" }
      },
      "patterns": [
        {
          "name": "constant.character.escape.holyc",
          "match": "\\\\(?:[abefnrtv\\\\\"'?0]|x[0-9A-Fa-f]+|[0-7]+)"
        },
        {
          "name": "constant.character.escape.doldoc.holyc",
          "match": "\\$\\$"
        },
        {
          "name": "constant.other.placeholder.doldoc.holyc",
          "match": "\\$[A-Z][^$]*\\$"
        },
        {
          "name": "constant.other.placeholder.holyc",
          "match": "%[-+0# ]*[0-9*]*(?:\\.[0-9*]+)?[hljztL]?[diouxXeEfgGaAcspn%]"
        }
      ]
    },
    "chars": {
      "name": "string.quoted.single.holyc",
      "begin": "'",
      "end": "'",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.holyc" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.holyc" }
      },
      "patterns": [
        {
          "name": "constant.character.escape.holyc",
          "match": "\\\\(?:[abefnrtv\\\\\"'?0]|x[0-9A-Fa-f]+|[0-7]+)"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.holyc",
          "match": "\\b0[xX][0-9A-Fa-f_]+\\b"
        },
        {
          "name": "constant.numeric.binary.holyc",
          "match": "\\b0[bB][01_]+\\b"
        },
        {
          "name": "constant.numeric.float.holyc",
          "match": "\\b[0-9][0-9_]*\\.[0-9_]+(?:[eE][+-]?[0-9]+)?\\b|\\b[0-9][0-9_]*[eE][+-]?[0-9]+\\b"
        },
        {
          "name": "constant.numeric.decimal.holyc",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "constants": {
      "name": "constant.language.holyc",
      "match": "\\b(TRUE|FALSE|NULL|ON|OFF|INVALID_PTR)\\b"
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.holyc",
          "match": "\\b(U0|U8|U16|U32|U64|I0|I8|I16|I32|I64|F64|Bool)\\b"
        },
        {
          "name": "storage.type.class.holyc",
          "match": "\\b(C[A-Z][A-Za-z0-9_]*)\\b"
        }
      ]
    },
    "storage-modifiers": {
      "name": "storage.modifier.holyc",
      "match": "\\b(extern|_extern|import|_import|public|static|interrupt|haserrcode|argpop|noargpop|reg|noreg|no_warn|lastclass|lock)\\b"
    },
    "control-keywords": {
      "name": "keyword.control.holyc",
      "match": "\\b(if|else|while|for|do|switch|case|default|break|continue|goto|return|try|catch|throw|start|end)\\b"
    },
    "other-keywords": {
      "patterns": [
        {
          "name": "keyword.operator.sizeof.holyc",
          "match": "\\b(sizeof|offset)\\b"
        },
        {
          "name": "keyword.other.holyc",
          "match": "\\b(class|union|asm|ALIGN|BINFILE|DU8|DU16|DU32|DU64|ORG|USE16|USE32|USE64)\\b"
        }
      ]
    },
    "asm-block": {
      "name": "meta.asm.holyc",
      "begin": "\\b(asm)\\b\\s*(\\{)",
      "end": "\\}",
      "beginCaptures": {
        "1": { "name": "keyword.other.asm.holyc" },
        "2": { "name": "punctuation.section.block.begin.holyc" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.section.block.end.holyc" }
      },
      "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#numbers" },
        {
          "name": "support.function.asm.label.holyc",
          "match": "^\\s*([A-Z_][A-Z0-9_]*)::?",
          "captures": {
            "1": { "name": "entity.name.label.holyc" }
          }
        }
      ]
    },
    "builtin-functions": {
      "name": "support.function.builtin.holyc",
      "match": "\\b(Print|PrintErr|PutChars|PutS|GetChar|GetS|DocPrint|DocForm|MAlloc|CAlloc|Free|MSize|MemSet|MemCpy|MemCmp|StrLen|StrCmp|StrCpy|StrCat|StrPrint|StrNew|ToUpper|ToLower|Spawn|Sys|Once|OnceExe|Sleep|Yield|TaskExe|Exit|Kill|ExeFile|ExePrint|JobsHandler|RFlagsGet|Bt|Bts|Btr|FileWrite|FileRead|FileFind|Cd|Dir|CommInit8n1|CommPrint|CommPutChar|CommPutS|CommGetChar|FifoU8New|FifoU8Del|FifoU8Insert|FifoU8Remove|FifoU8Cnt|BlkDevNextFreeSlot|BlkDevAdd|AHCIPortInit|TCPSocketListen|TCPSocketAccept|TCPSocketBind|TCPSocketClose|OutU8|OutU16|OutU32|InU8|InU16|InU32|ToI64|ToBool|ToF64)\\b(?=\\s*[(;,)])"
    },
    "function-definition": {
      "match": "\\b(U0|U8|U16|U32|U64|I0|I8|I16|I32|I64|F64|Bool|C[A-Z][A-Za-z0-9_]*)\\s*(\\*+\\s*)?([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "storage.type.holyc" },
        "2": { "name": "keyword.operator.pointer.holyc" },
        "3": { "name": "entity.name.function.holyc" }
      }
    },
    "function-call": {
      "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.call.holyc" }
      }
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.holyc",
          "match": "(=|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=)"
        },
        {
          "name": "keyword.operator.comparison.holyc",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.holyc",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.bitwise.holyc",
          "match": "(<<|>>|&|\\||\\^|~)"
        },
        {
          "name": "keyword.operator.arithmetic.holyc",
          "match": "(\\+\\+|--|\\+|-|\\*|/|%|`)"
        },
        {
          "name": "keyword.operator.member.holyc",
          "match": "(->|\\.\\.\\.|\\.|::)"
        }
      ]
    }
  }
}
