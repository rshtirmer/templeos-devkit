# ZealOS / TempleOS ISO + installed disk — fetched/built locally, not committed
vendor/zealos/*.iso
vendor/zealos/*.qcow2
vendor/templeos/*.iso
vendor/templeos/*.qcow2

# Ephemeral build artifacts
build/

# macOS
.DS_Store

# Editor
*.swp
.idea/
.vscode/*
# Workspace-level editor config we DO want shared (lint task + file
# associations for the HolyC extension). Personal stuff like launch.json
# and per-user settings remain ignored above.
!.vscode/tasks.json
!.vscode/settings.json

# Python bytecode
__pycache__/
*.pyc

# Rust build output (holyc-parser/) — keep Cargo.lock since holycc is a bin
target/
